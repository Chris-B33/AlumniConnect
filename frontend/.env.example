# Base URL for the API Gateway (optional for local dev).
# If unset, the app defaults to http://localhost:8080 — see src/services/api.js.
# Copy to .env only when you need a non-default value (e.g. staging).
# Example values:
#   Local dev  → http://localhost:8080
#   Staging    → https://staging-api.alumniconnect.ul.ie
#   Production → https://api.alumniconnect.ul.ie
VITE_API_BASE_URL=http://localhost:8080
