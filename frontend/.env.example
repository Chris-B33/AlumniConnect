# Base URL for the API Gateway.
# Local dev  → http://localhost:8080
# Staging    → https://staging-api.alumniconnect.ul.ie
# Production → https://api.alumniconnect.ul.ie
VITE_API_BASE_URL=http://localhost:8080

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" to show the feature in the nav and enable its routes.
# Set to "false" (or omit) to hide until the backend is ready.

# Profile page — view/edit profile and avatar upload (Mark's API)
VITE_FEATURE_PROFILE=true

# Chat page — thread list, messages, real-time send (Michael's API)
VITE_FEATURE_CHAT=true

# ─── Chat options (only relevant if VITE_FEATURE_CHAT=true) ───────────────────
# WebSocket URL for the chat service.
# Leave blank to fall back to polling mode.
VITE_CHAT_WS_URL=ws://localhost:8080/ws/chat

# Polling interval in ms — used when VITE_CHAT_WS_URL is blank or WS fails.
VITE_CHAT_POLL_INTERVAL_MS=3000
